{
  "manifest_version": 3,
  "name": "smrtVault",
  "version": "1.0.0",
  "description": "Autofill your smrtVault logins securely. A password is fetched only at fill time and typed straight into the site — never shown in the extension and never stored on your device.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "smrtVault",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "permissions": ["cookies", "storage", "alarms", "scripting", "activeTab", "notifications"],
  "host_permissions": ["https://*.smrtesy.com/*", "https://*.supabase.co/*", "https://claude.ai/*"],
  "optional_host_permissions": ["https://*/*"],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/code/*"],
      "js": ["claude-capture.js"],
      "run_at": "document_idle"
    }
  ]
}
