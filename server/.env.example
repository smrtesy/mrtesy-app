# Supabase (service role — never expose to client)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth (same credentials as Next.js app)
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# WhatsApp Google Sheet
WHATSAPP_SHEET_ID=1_0hZE_gTzAyN-DHWhaxSQEnF4tJm1XL6nFUSJngtuaI
WHATSAPP_SHEET_TAB=Messages

# ─── smrtVoice integration ──────────────────────────────────────────────────
# Base URL of the voice-engine service (no trailing slash).
VOICE_ENGINE_URL=https://voice-engine.up.railway.app

# Static Bearer token; must match VOICE_ENGINE_API_KEY in voice-engine.
VOICE_ENGINE_API_KEY=

# HMAC secret for verifying webhooks from voice-engine.
# Must match WEBHOOK_SIGNING_SECRET in voice-engine.
VOICE_ENGINE_WEBHOOK_SECRET=

# Public URL of this smrtesy backend — voice-engine posts webhooks to
# `${SMRTESY_PUBLIC_URL}/api/voice/webhook`.
SMRTESY_PUBLIC_URL=https://smrtesy.up.railway.app
